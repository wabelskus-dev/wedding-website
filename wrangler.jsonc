{
  "name": "wedding-website",
  "main": "src/worker.js",
  "compatibility_date": "2026-07-01",
  "routes": [
    {
      "pattern": "briandliam.com/*",
      "zone_name": "briandliam.com"
    },
    {
      "pattern": "www.briandliam.com/*",
      "zone_name": "briandliam.com"
    }
  ],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  }
}
